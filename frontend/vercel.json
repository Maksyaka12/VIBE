{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/r", "destination": "/r/index.html" },
    { "source": "/r/", "destination": "/r/index.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/docs/(.*)", "destination": "/docs.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
